# ============================================================
# AI 助手配置 — Claude Code CLI 后端
# ============================================================
# Claude Code CLI 支持自定义 API 端点，可接入千问、DeepSeek 等
# 兼容 Anthropic API 格式的大模型服务。
#
# 配置方式：复制本文件为 .env，填入对应的值即可。
# cp .env.example .env
# ============================================================

# --- 方式一：阿里千问 Qwen（推荐，国内可用）---
# 获取 API Key: https://bailian.console.aliyun.com/ → API-KEY 管理
# 可用模型: qwen3-coder-plus / qwen-max / qwen-plus / qwen-turbo
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_AUTH_TOKEN=your-qwen-api-key
ANTHROPIC_MODEL=qwen3-coder-plus

# --- 方式二：DeepSeek ---
# 获取 API Key: https://platform.deepseek.com/api_keys
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-deepseek-api-key
# ANTHROPIC_MODEL=deepseek-chat

# --- 方式三：Anthropic 原生（需海外网络）---
# 获取 API Key: https://console.anthropic.com/
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
